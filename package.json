{
  "name": "@idea404/repocontext",
  "version": "0.1.6",
  "description": "The only MCP server you need for context-efficient codebase learning",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
